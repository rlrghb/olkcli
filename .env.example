# Optional: Override the default embedded client ID
# OLK_CLIENT_ID=your-azure-app-client-id

# Optional: Specify tenant (defaults to "common" for both personal + enterprise)
# OLK_TENANT_ID=your-tenant-id

# Optional: Override config directory (defaults to ~/.config/olkcli/)
# OLK_CONFIG_DIR=/path/to/config

# Optional: Default output format
# OLK_JSON=true
# OLK_PLAIN=true

# Optional: Default account for multi-account setups
# OLK_ACCOUNT=user@example.com

# Optional: Color mode
# OLK_COLOR=auto
